# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Neon Postgres) ---
# Pooled connection (used by app at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx.aws.neon.tech/fnb_erp?sslmode=require&pgbouncer=true&connect_timeout=10"
# Direct connection (used by Prisma migrate). Do NOT use pgbouncer here.
DIRECT_URL="postgresql://user:password@ep-xxx.aws.neon.tech/fnb_erp?sslmode=require"

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/overview
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/overview
CLERK_WEBHOOK_SECRET=whsec_xxx

# --- Inngest (Month 3+) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Pusher (Month 3+) ---
PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=ap1

# --- Cloudflare R2 (Month 2+) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fnb-erp

# --- Sentry (Week 2) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- E-Invoice provider (Month 3) ---
EINVOICE_PROVIDER=misa
EINVOICE_API_KEY=
EINVOICE_API_URL=
